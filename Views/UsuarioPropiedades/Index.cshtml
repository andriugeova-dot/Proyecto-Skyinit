@{
    Layout = "~/Views/Shared/_LayoutUsuarioPropiedades.cshtml";
}
@model List<Proyecto_SkyInit.Models.Propiedad>


<!DOCTYPE html>
<html lang="es">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Propiedades - SkyInit</title>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">

</head>

<body>

    <header id="header">
        <div class="topbar">
            <div class="logo">SkyInit</div>
            <div class="menu-toggle" onclick="toggleMenu()">&#9776;</div>
            <nav id="menu">
                <a asp-controller="Menu" asp-action="Index">Inicio</a>
                <a asp-controller="Menu" asp-action="Propiedades">Propiedades</a>
                <a asp-controller="Menu" asp-action="Proyectos">Proyectos</a>
                <a asp-controller="Menu" asp-action="Servicios">Servicios</a>
                <a asp-controller="Menu" asp-action="Constructoras">Constructoras</a>
                @if (User.Identity!.IsAuthenticated)
                {
                    <div class="user-profile">
                        <img src="@(ViewBag.FotoPerfil ?? "/img/default-avatar.svg")"
                             alt="Avatar"
                             class="profile-pic"
                             onclick="toggleUserMenu()" />
                        <div id="user-menu" class="user-menu">
                            <div class="user-menu-name">@User.Identity.Name</div>
                            <a asp-controller="Login" asp-action="Ajustes">⚙️ Ajustes</a>
                            <a asp-controller="Login" asp-action="Logout">🚪 Cerrar sesión</a>
                        </div>
                    </div>
                }
                else
                {
                    <a asp-controller="Login" asp-action="Index" class="btn-registrar">Iniciar Sesión</a>
                }
            </nav>
        </div>

        <div class="hero-inner">
            <div class="hero-eyebrow">Catálogo completo</div>
            <h1>Encuentra tu <em>propiedad ideal</em></h1>
            <p class="hero-sub">Explora casas, apartamentos y encuentra el hogar que se ajusta a lo que buscas.</p>
        </div>
    </header>

    <section class="search-container">
        <form asp-controller="UsuarioPropiedades" asp-action="Buscar" method="get" class="search-box">
            <input type="text" name="query" placeholder="Buscar por título o descripción..." />

            <select name="tipoOperacion">
                <option value="">-- Tipo de operación --</option>
                <option value="1">Venta</option>
                <option value="2">Arriendo</option>
                <option value="3">Empeño</option>
            </select>

            <select name="habitaciones">
                <option value="">-- Habitaciones --</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3+</option>
            </select>

            <input type="text" name="ciudad" placeholder="Ciudad" />

            <button type="submit">Buscar</button>
        </form>
    </section>

    <section class="contenedor resultados-section">

        <div class="header-destacadas">
            <div class="textos-destacadas">
                <span class="etiqueta-destacadas">Catálogo</span>
                <h2 class="titulo-destacadas">
                    @(Model != null ? Model.Count : 0) propiedades disponibles
                </h2>
                <p class="sub-destacadas">Explora el listado completo y encuentra la opción que mejor se adapte a ti</p>
            </div>
        </div>

        <div class="properties">
            @if (Model != null && Model.Any())
            {
                @foreach (var propiedad in Model)
                {
                    <div class="property-card">
                        <div class="property-image">
                            <img src="@(propiedad.Imagenes.FirstOrDefault()?.URL ?? "/images/no-image.png")" alt="@propiedad.Titulo" />

                            @{
                                var tipoOperacion = propiedad.TipoOperacion?.Descripcion?.ToLower() ?? "";
                                var badgeClass = "badge-default";
                                if (tipoOperacion.Contains("venta")) badgeClass = "badge-venta";
                                if (tipoOperacion.Contains("arriendo")) badgeClass = "badge-arriendo";
                            }
                            <span class="badge-tipo @badgeClass">@propiedad.TipoOperacion?.Descripcion</span>

                            <button type="button"
                                    class="btn-favorito @(propiedad.EsFavorito ? "favorito-activo" : "favorito-inactivo")"
                                    data-id="@propiedad.PropiedadID">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                                </svg>
                            </button>
                        </div>

                        <div class="property-info">
                            <div class="precio-container">
                                <h3>@propiedad.Precio.ToString("C0")</h3>
                            </div>

                            <h2>@propiedad.Titulo</h2>

                            <p class="location">
                                <svg class="icono-pin" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"></path>
                                </svg>
                                <span>@(propiedad.Ciudad ?? propiedad.Direccion)</span>
                            </p>

                            <p class="description">@propiedad.Descripcion</p>

                            <div class="details">
                                <span>🛏️ @(propiedad.Habitaciones ?? 0) Habitaciones</span>
                            </div>

                            <a asp-controller="UsuarioPropiedades" asp-action="Detalle" asp-route-id="@propiedad.PropiedadID"
                               class="link-detalle-propiedad enlace-absoluto"
                               data-id="@propiedad.PropiedadID"
                               data-require-sesion="@Html.Raw(User.Identity!.IsAuthenticated ? "false" : "true")"></a>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="sin-resultados">No se encontraron propiedades con los filtros seleccionados.</p>
            }
        </div>
    </section>

    <div id="modalRegistro" class="modal-overlay" onclick="cerrarModalRegistro(event)">
        <div class="modal-box modal-box-login">
            <button class="modal-close" onclick="cerrarModalRegistro()">X</button>
            <div class="modal-info">
                <h2>Debes estar registrado</h2>
                <p>Para guardar favoritos debes iniciar sesion</p>
                <div class="acciones-login">
                    <a asp-controller="Login" asp-action="Index" class="btn-contacto">Iniciar Sesion</a>
                </div>
            </div>
        </div>
    </div>

    <div id="modalPropiedad" class="modal">
        <div class="modal-content modal-content-propiedad">
            <span class="modal-close">&times;</span>
            <div id="modal-body">
                <h2 id="modalTitulo"></h2>
                <img id="modalImagen" src="" alt="Imagen propiedad" class="modal-img-propiedad" />
                <p id="modalDescripcion"></p>

                <div class="modal-detalles-grid">
                    <p id="modalPrecio"></p>
                    <p id="modalUbicacion"></p>
                    <p id="modalTipoOperacion"></p>
                    <p id="modalHabitaciones"></p>
                </div>

                <div class="modal-contacto">
                    <div class="modal-agente" id="modalAgenteWrap">
                        <img id="modalAgenteFoto" src="" alt="Foto del agente" class="modal-avatar" />
                        <div class="modal-contacto-info">
                            <span class="modal-contacto-label">Agente encargado</span>
                            <p id="modalAgenteNombre"></p>
                        </div>
                    </div>

                    <div class="modal-constructora" id="modalConstructoraWrap">
                        <img id="modalConstructoraLogo" src="" alt="Logo de la constructora" class="modal-logo" />
                        <div class="modal-contacto-info">
                            <span class="modal-contacto-label">Constructora</span>
                            <p id="modalConstructoraNombre"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function toggleMenu() {
            document.getElementById("menu").classList.toggle("active");
        }

        function toggleUserMenu() {
            document.getElementById("user-menu").classList.toggle("active");
        }
    </script>
    <script>
        // Fondo del hero con cambio automático de imagen (solo decorativo)
        const propiedadesHeroImages = [
            "https://images.unsplash.com/photo-1600585154340-be6161a56a0c",
            "https://images.unsplash.com/photo-1568605114967-8130f3a36994",
            "https://images.unsplash.com/photo-1570129477492-45c003edd2be"
        ];
        let propiedadesHeroIndex = 0;
        const propiedadesHeroHeader = document.getElementById("header");

        function cambiarFondoHero() {
            propiedadesHeroHeader.style.backgroundImage = `url(${propiedadesHeroImages[propiedadesHeroIndex]})`;
            propiedadesHeroIndex = (propiedadesHeroIndex + 1) % propiedadesHeroImages.length;
        }
        cambiarFondoHero();
        setInterval(cambiarFondoHero, 5000);
    </script>
    <script>
        document.querySelectorAll(".link-detalle-propiedad").forEach(link => {
            link.addEventListener("click",(e) => {
                if (link.dataset.requireSesion === "true"){
                    e.preventDefault();
                    document.getElementById("modalRegistro").style.display = "flex";
                }
            })
        })
    </script>
    <script>
        document.querySelectorAll(".btn-favorito").forEach(btn => {
            btn.addEventListener("click", async () => {
                const propiedadId = btn.getAttribute("data-id");

                const response = await fetch("/Favoritos/Toggle", {
                    method: "POST",
                    headers: { "Content-Type": "application/x-www-form-urlencoded" },
                    body: `propiedadId=${propiedadId}`
                });

                if (response.ok) {
                    btn.classList.toggle("favorito-activo");
                    btn.classList.toggle("favorito-inactivo");
                } else if (response.status === 401) {
                    document.getElementById("modalRegistro").classList.add("open");
                }
            });
        });

        function cerrarModalRegistro(event){
            if (!event || event.target.id === "modalRegistro") {
            document.getElementById("modalRegistro").classList.remove("open");
            }
        }
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('modalPropiedad');
            const closeBtn = document.querySelector('#modalPropiedad .modal-close');
            const botonesVerMas = document.querySelectorAll('.link-detalle-propiedad');

            const formatoPesos = new Intl.NumberFormat('es-CO', {
                style: 'currency',
                currency: 'COP',
                minimumFractionDigits: 0
            });

            botonesVerMas.forEach(boton => {
                boton.addEventListener('click', async (e) => {
                    e.preventDefault();
                    if (boton.dataset.requireSesion === "true"){
                        document.getElementById("modalRegistro").classList.add("open");
                        return;
                    }
                    const propiedadId = boton.dataset.id;

                    try {
                        const response = await fetch(`/UsuarioPropiedades/ObtenerDetalles/${propiedadId}`);
                        if (!response.ok) throw new Error("No se pudo cargar la info");

                        const data = await response.json();

                        document.getElementById('modalTitulo').textContent = data.titulo;
                        document.getElementById('modalImagen').src = data.imagenUrl;
                        document.getElementById('modalDescripcion').textContent = data.descripcion;
                        document.getElementById('modalPrecio').textContent = formatoPesos.format(data.precio);
                        document.getElementById('modalUbicacion').textContent = `Ubicación: ${data.direccion}, ${data.ciudad}`;
                        document.getElementById('modalTipoOperacion').textContent = `Operación: ${data.tipoOperacion}`;
                        document.getElementById('modalHabitaciones').textContent = data.habitaciones
                            ? `Habitaciones: ${data.habitaciones}`
                            : 'Habitaciones: No especificado';

                        const agenteWrap = document.getElementById('modalAgenteWrap');
                        if (data.agenteNombre) {
                            document.getElementById('modalAgenteNombre').textContent = data.agenteNombre;
                            document.getElementById('modalAgenteFoto').src = data.agenteFoto;
                            agenteWrap.style.display = 'flex';
                        } else {
                            agenteWrap.style.display = 'none';
                        }

                        const constructoraWrap = document.getElementById('modalConstructoraWrap');
                        const constructoraLogoImg = document.getElementById('modalConstructoraLogo');
                        if (data.constructoraNombre) {
                            document.getElementById('modalConstructoraNombre').textContent = data.constructoraNombre;
                            if (data.constructoraLogo) {
                                constructoraLogoImg.src = data.constructoraLogo;
                                constructoraLogoImg.style.display = 'block';
                            } else {
                                constructoraLogoImg.style.display = 'none';
                            }
                            constructoraWrap.style.display = 'flex';
                        } else {
                            constructoraWrap.style.display = 'none';
                        }

                        modal.classList.add('active');
                    } catch (error) {
                        console.error("Error cargando los detalles:", error);
                        alert("Hubo un error al cargar la información de la propiedad.");
                    }
                });
            });

            closeBtn.addEventListener('click', () => modal.classList.remove('active'));
            window.addEventListener('click', (e) => {
                if (e.target === modal) modal.classList.remove('active');
            });
        });
    </script>

</body>
</html>