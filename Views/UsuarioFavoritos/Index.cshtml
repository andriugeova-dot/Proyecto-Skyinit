@model IEnumerable<Proyecto_SkyInit.Models.Favorito>
@{
    Layout = "~/Views/Shared/_LayoutUsuarioFavoritos.cshtml";
    ViewData["Title"] = "Mis Favoritos";
}
<div class="user-container">

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="logo">
            <h2>SkyInit</h2>
            <span>Panel Usuario</span>
        </div>
        <nav>
            <a asp-controller="PanelUsuario" asp-action="Index">🏠 Panel Principal</a>
            <a asp-controller="UsuarioPerfil" asp-action="Index">👤 Perfil</a>
            <a asp-controller="PanelUsuario" asp-action="Favoritos">⭐ Favoritos</a>
            <a asp-controller="UsuariosSolicitudServicios" asp-action="Index">🛠️ Mantenimiento</a>
            <a asp-controller="Menu" asp-action="Inicio">⬅️ Volver al menú</a>
            <a asp-controller="Login" asp-action="Logout">🚪 Cerrar sesión</a>
        </nav>
    </aside>

    <!-- Content -->
    <main class="content">
        <div class="topbar">
            <h1>Mis Propiedades Favoritas</h1>
            <p>Aquí puedes ver y gestionar tus favoritos.</p>
        </div>

        <section class="favorite-list">
            @if (!Model.Any())
            {
                <p class="sin-favoritos">Todavía no has guardado ninguna propiedad como favorita.</p>
            }
            else
            {
                @foreach (var fav in Model)
                {
                    var propiedad = fav.Propiedad;
                    var imgUrl = propiedad.Imagenes.FirstOrDefault()?.URL ?? "/img/no-image.png";

                    <div class="favorite-item">
                        <div class="favorite-image">
                            <img src="@imgUrl" alt="@propiedad.Titulo" />
                        </div>
                        <div class="favorite-info">
                            <h4>@propiedad.Titulo</h4>
                            <p>📍 @(string.IsNullOrEmpty(propiedad.Ciudad) ? propiedad.Direccion : propiedad.Ciudad)</p>
                            <p>@propiedad.Precio.ToString("C0", new System.Globalization.CultureInfo("es-CO"))</p>
                            <form asp-action="Quitar" method="post">
                                <input type="hidden" name="propiedadId" value="@propiedad.PropiedadID" />
                                <button type="submit" class="btn">✕ Quitar</button>
                            </form>
                        </div>
                    </div>
                }
            }
        </section>
    </main>
</div>
