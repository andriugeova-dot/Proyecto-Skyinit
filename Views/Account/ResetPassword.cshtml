@model Proyecto_SkyInit.Models.ResetPasswordViewModel

@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Nueva Contraseña";
}

<div class="login-container">
    <h2>SkyInit</h2>
    <p style="font-size:13px; opacity:0.85; margin-bottom:15px;">
        Ingresa tu nueva contraseña.
    </p>

    @if (ViewBag.Error != null)
    {
        <div class="colorerror">@ViewBag.Error</div>
    }

    <form asp-controller="Account" asp-action="ResetPassword" method="post">
        <input type="hidden" asp-for="Token" />
        <div class="input-group">
            <label>Nueva contraseña</label>
            <input type="password" asp-for="NuevaContrasena" placeholder="****" required />
        </div>
        <button type="submit" class="btn btn-login">Restablecer contraseña</button>
    </form>

    <div class="extra">
        <a asp-controller="Login" asp-action="Index">← Volver al inicio de sesión</a>
    </div>
</div>

@section Scripts {
    <script>
        const images = [
            "https://images.unsplash.com/photo-1600585154340-be6161a56a0c",
            "https://images.unsplash.com/photo-1568605114967-8130f3a36994",
            "https://images.unsplash.com/photo-1570129477492-45c003edd2be"
        ];
        let index = 0;
        function changeBackground() {
            document.body.style.backgroundImage = `url(${images[index]})`;
            index = (index + 1) % images.length;
        }
        changeBackground();
        setInterval(changeBackground, 5000);
    </script>
}
