@{
    ViewData["Title"] = "Home Page";
}

<h2>Estado de la base de datos</h2>

@if (ViewBag.Estado != null)
{
    <div style="padding: 15px; background-color: #d4edda; color: #155724;
                border: 1px solid #c3e6cb; border-radius: 5px; margin-top: 20px;">
        @ViewBag.Estado
    </div>
}
else
{
    <div style="padding: 15px; background-color: #f8d7da; color: #721c24;
                border: 1px solid #f5c6cb; border-radius: 5px; margin-top: 20px;">
        ❌ No se pudo conectar a la base de datos
    </div>
}