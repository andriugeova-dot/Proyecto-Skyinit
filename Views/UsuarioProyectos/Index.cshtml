@model IEnumerable<Proyecto_SkyInit.Models.Proyecto>
@{
    Layout = "~/Views/Shared/_LayoutUsuarioProyectos.cshtml";
}
<!DOCTYPE html>
<html lang="es">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Proyectos - SkyInit</title>

    <link rel="stylesheet" href="proyectos.css">

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">

</head>

<body>

    <header>

        <div class="topbar">
            <div class="logo">SkyInit</div>
            <div class="menu-toggle" onclick="toggleMenu()">&#9776;</div>
            <nav id="menu">
                <a asp-controller="Menu" asp-action="Index">Inicio</a>
                <a asp-controller="Menu" asp-action="Propiedades">Propiedades</a>
                <a asp-controller="Menu" asp-action="Proyectos">Proyectos</a>
                <a asp-controller="Menu" asp-action="Servicios">Servicios</a>
                <a asp-controller="Menu" asp-action="Constructoras">Constructoras</a>
                @if (User.Identity!.IsAuthenticated)
                {
                    <div class="user-profile">
                        <img src="@(ViewBag.FotoPerfil ?? "/img/default-avatar.svg")"
                             alt="Perfil"
                             class="profile-pic"
                             onclick="toggleUserMenu()" />
                        <div id="user-menu" class="user-menu">
                            <div class="user-menu-name">@User.Identity.Name</div>
                            <a asp-controller="Login" asp-action="Ajustes">⚙️ Ajustes</a>
                            <a asp-controller="Login" asp-action="Logout">🚪 Cerrar sesión</a>
                        </div>
                    </div>
                }
                else
                {
                    <a asp-controller="Login" asp-action="Index" class="btn-registrar">Iniciar Sesión</a>
                }
            </nav>
        </div>
    </header>

    <h1 class="title">
        Proyectos
    </h1>

    <section class="projects">
        @foreach (var proyecto in Model)
            {
                var imgUrl = proyecto.ImagenesProyecto?.FirstOrDefault()?.URL ?? "";
                var bgStyle = !string.IsNullOrEmpty(imgUrl)
                ? $"background-image: url('{imgUrl}'); background-size: cover; background-position: center;"
                : "";

                <div class="card" style="@bgStyle">
                    <div class="card-overlay"></div>
                        <div class="content">
                        <h3>@proyecto.Nombre</h3>
                        <p>
                            Estado : @proyecto.EstadoProyecto?.Descripcion <br />
                            Constructora: @proyecto.Constructora?.Nombre <br />
                            Inicio: @proyecto.FechaInicio?.ToString("dd/MM/yyy") <br />
                            Fin: @proyecto.FechaFin?.ToString("dd/MM/yyy")
                        </p>
                    <button onclick="abrirModal(
                        '@Html.Raw(proyecto.Nombre.Replace("'", "\\'"))',
                        '@Html.Raw((proyecto.Constructora?.Nombre ?? "").Replace("'", "\\'"))',
                        '@Html.Raw((proyecto.Descripcion ?? "").Replace("'", "\\'"))',
                        '@imgUrl')">
                        Ver más
                    </button>
                    </div>
                </div>
            }
    </section>
    <!-- FLOTANTE-->
            <div id="modal" class="modal-overlay" onclick="cerrarModal(event)">
            <div class="modal-box">
                <button class="modal-close" onclick="cerrarModal()">X</button>
                <img id="modal-img" src="" alt="Imagen del proyecto" />
                <div class="modal-info">
                    <h2 id="modal-nombre"></h2>
                    <p><strong>Constructora: </strong><span id="modal-constructora"></span></p>
                    <p><strong>Descripcion: </strong><span id="modal-descripcion"></span></p>
                    <button class="btn-contacto">Contacto</button>
                </div>
            </div>
    </div>
    <div id="modalRegistro" class="modal-overlay" onclick="cerrarModalRegistro(event)">
        <div class="modal-box modal-box-login">
            <button class="modal-close" onclick="cerrarModalRegistro()">X</button>
            <div class="modal-info">
                <h2>Debes iniciar sesion</h2>
                <p>Para ver mas detalles de este proyecto debes iniciar sesión en tu cuenta.</p>
                <div class="acciones-login">
                    <a asp-controller="Login" asp-action="Index" class="btn-contacto">Iniciar Sesión</a>
                </div>
            </div>
        </div>
    </div>
    
    <script>

        const usuarioAutenticado = @Html.Raw(User.Identity!.IsAuthenticated ? "true" : "false");

        function toggleUserMenu() {
            document.getElementById("user-menu").classList.toggle("active");
        }
        function abrirModal(nombre,constructora,descripcion,imgUrl) {
            if (!usuarioAutenticado){
                abrirModalRegistro();
                return;
            }
            document.getElementById("modal-nombre").textContent = nombre;
            document.getElementById("modal-constructora").textContent = constructora || "-";
            document.getElementById("modal-descripcion").textContent = descripcion || "-";
            document.getElementById("modal-img").src = imgUrl || "";
            document.getElementById("modal-img").style.display = imgUrl ? "block" : "none";
            document.getElementById("modal").classList.add("open");
        }
        function cerrarModal(event){
            if (!event || event.target.id === "modal") {
                document.getElementById("modal").classList.remove("open");
             }
        }
        function abrirModalRegistro(){
            document.getElementById("modalRegistro").classList.add("open");
        }
        function cerrarModalRegistro(){
            if(!event || event.target.id === "modalRegistro"){
                document.getElementById("modalRegistro").classList.remove("open");
            }
        }
    </script>

</body>
</html>