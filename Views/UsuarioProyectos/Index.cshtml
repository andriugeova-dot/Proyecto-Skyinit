@model IEnumerable<Proyecto_SkyInit.Models.Proyecto>
@{
    Layout = "~/Views/Shared/_LayoutUsuarioProyectos.cshtml";

    var heroImages = Model
        .SelectMany(p => p.ImagenesProyecto ?? new List<Proyecto_SkyInit.Models.ImagenProyecto>())
        .Select(i => i.URL)
        .Where(u => !string.IsNullOrEmpty(u))
        .Distinct()
        .Take(6)
        .ToList();
    var heroImagesJson = string.Join(",", heroImages.Select(u => $"\"{u}\""));
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Proyectos - SkyInit</title>
    <link rel="stylesheet" href="~/css/UsuarioProyectos.css" asp-append-version="true">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
</head>
<body>

    <header id="header-proyectos">
        <div class="topbar">
            <div class="logo">SkyInit</div>
            <div class="menu-toggle" onclick="toggleMenu()">&#9776;</div>
            <nav id="menu">
                <a asp-controller="Menu" asp-action="Index">Inicio</a>
                <a asp-controller="Menu" asp-action="Propiedades">Propiedades</a>
                <a asp-controller="Menu" asp-action="Proyectos">Proyectos</a>
                <a asp-controller="Menu" asp-action="Servicios">Servicios</a>
                <a asp-controller="Menu" asp-action="Constructoras">Constructoras</a>
                @if (User.Identity!.IsAuthenticated)
                {
                    <div class="user-profile">
                        <img src="@(ViewBag.FotoPerfil ?? "/img/default-avatar.svg")"
                             alt="Perfil"
                             class="profile-pic"
                             onclick="toggleUserMenu()" />
                        <div id="user-menu" class="user-menu">
                            <div class="user-menu-name">@User.Identity.Name</div>
                            <a asp-controller="Login" asp-action="Ajustes">⚙️ Ajustes</a>
                            <a asp-controller="Login" asp-action="Logout">🚪 Cerrar sesión</a>
                        </div>
                    </div>
                }
                else
                {
                    <a asp-controller="Login" asp-action="Index" class="btn-registrar">Iniciar Sesión</a>
                }
            </nav>
        </div>

        <div class="hero-inner">
            <div class="hero-eyebrow">Desarrollos inmobiliarios</div>
            <h1>Proyectos que <em>construyen futuro</em></h1>
            <p class="hero-sub">Conoce los desarrollos en los que estamos trabajando junto a nuestras constructoras aliadas.</p>
        </div>
    </header>

    <section class="contenedor">
        <div class="header-proyectos-section">
            <div class="textos-proyectos">
                <span class="etiqueta-proyectos">Nuestro portafolio</span>
                <h2 class="titulo-proyectos">Proyectos en desarrollo</h2>
                <p class="sub-proyectos">Explora el estado, las fechas y la constructora encargada de cada proyecto</p>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="proyectos-grid">
                @foreach (var proyecto in Model)
                {
                    var imgUrl = proyecto.ImagenesProyecto?.FirstOrDefault()?.URL ?? "/images/no-image.png";

                    var estadoDesc = proyecto.EstadoProyecto?.Descripcion ?? "Sin estado";
                    var estadoLower = estadoDesc.ToLower();
                    var estadoClass = "badge-default";
                    if (estadoLower.Contains("construc")) estadoClass = "badge-construccion";
                    if (estadoLower.Contains("final") || estadoLower.Contains("terminado") || estadoLower.Contains("entregado")) estadoClass = "badge-finalizado";

                    var constructoraNombre = proyecto.Constructora?.Nombre ?? "Constructora no asignada";
                    var fechaIni = proyecto.FechaInicio?.ToString("dd/MM/yyyy") ?? "Por definir";
                    var fechaFin = proyecto.FechaFin?.ToString("dd/MM/yyyy") ?? "Por definir";
                    var descripcion = proyecto.Descripcion ?? "Sin descripción disponible.";

                    var nombreEsc = proyecto.Nombre.Replace("'", "\\'");
                    var constructoraEsc = constructoraNombre.Replace("'", "\\'");
                    var estadoEsc = estadoDesc.Replace("'", "\\'");
                    var descripcionEsc = descripcion.Replace("'", "\\'").Replace("\n", " ");

                    <div class="proyecto-card">
                        <div class="proyecto-img-container">
                            <img src="@imgUrl" alt="@proyecto.Nombre" />
                            <span class="badge-estado @estadoClass">@estadoDesc</span>
                        </div>

                        <div class="proyecto-body">
                            <h3 class="proyecto-titulo">@proyecto.Nombre</h3>

                            <div class="proyecto-meta">
                                <span class="meta-item">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3 21h18"></path>
                                        <path d="M5 21V7l8-4v18"></path>
                                        <path d="M19 21V11l-6-4"></path>
                                    </svg>
                                    @constructoraNombre
                                </span>
                                <span class="meta-item">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                                        <line x1="16" y1="2" x2="16" y2="6"></line>
                                        <line x1="8" y1="2" x2="8" y2="6"></line>
                                        <line x1="3" y1="10" x2="21" y2="10"></line>
                                    </svg>
                                    @fechaIni - @fechaFin
                                </span>
                            </div>

                            <p class="proyecto-desc">@descripcion</p>

                            <button type="button" class="btn-ver-mas"
                                    onclick="abrirModal('@nombreEsc','@constructoraEsc','@estadoEsc','@estadoClass','@fechaIni','@fechaFin','@descripcionEsc','@imgUrl')">
                                Ver más
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="sin-proyectos">No hay proyectos registrados por el momento.</p>
        }
    </section>

