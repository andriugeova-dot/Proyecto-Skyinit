@using System.Linq
@model List<Proyecto_SkyInit.Models.Proyecto>

@{
    Layout = "_LayoutGestionProyectos";
}

<html lang="es">
<head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<!-- SIDEBAR -->
<aside class="sidebar">

    <div class="logo">
        <h2>Sky<span>Init</span></h2>
        <span class="rol-badge">Administrador</span>
    </div>

    <nav>
        <a asp-controller="Administrador" asp-action="Index">📝 Panel de control</a>
        <a asp-controller="Administrador" asp-action="Propiedades">🏡 Propiedades</a>
        <a asp-controller="Administrador" asp-action="Proyectos" class="active">🏗️ Proyectos</a>
        <a asp-controller="Administrador" asp-action="Agentes">👤 Usuarios</a>
        <a asp-controller="GestionMantenimientos" asp-action="Index">🛠️ Mantenimiento</a>
        <a asp-controller="GestionServicios" asp-action="Index">🧰 Servicios</a>
        <a asp-controller="Administrador" asp-action="Constructoras">🏅 Constructoras</a>
        @* <a asp-controller="Administrador" asp-action="Consultas">💬 Consultas</a>
        <a asp-controller="Administrador" asp-action="Comentarios">⭐ Comentarios</a>
        <a asp-controller="Administrador" asp-action="Historial">🕘 Historial</a>
        <a asp-controller="Administrador" asp-action="Notificaciones">🔔 Notificaciones</a> *@
        <a asp-controller="Login" asp-action="Logout">🚪 Cerrar sesión</a>

    </nav>

</aside>

<body>
    <!-- Toast -->
    @if (TempData["Mensaje"] != null)
    {
        <div class="toast @TempData["TipoMensaje"]" id="toast">
            @TempData["Mensaje"]
        </div>
        <script>
            setTimeout(() => {
                const t = document.getElementById('toast');
                if (t) t.style.opacity = '0';
                setTimeout(() => t?.remove(), 400);
            }, 3500);
        </script>
    }

   @*  <!-- Navbar -->
    <div class="navbar">
        <div class="logo">SkyInit</div>
        <div class="admin">
            <div><strong>Administrador</strong></div>
        </div>
    </div> *@

    <!-- Contenido -->
    <div class="container">
        <div class="header">
            <h1>Gestión de Proyectos</h1>
            <p>Administra, edita y elimina proyectos registrados.</p>
        </div>

        <!-- Buscador -->
        <form method="get" action="@Url.Action("Index", "GestionProyectos")">
            <div class="top-actions">
                <div class="search">
                    <input type="text" name="buscar" value="@ViewBag.Buscar"
                           placeholder="Buscar por nombre o constructora..." />
                </div>
                <button type="submit" class="add-btn" style="background:#073b4c;">Buscar</button>
                <a href="@Url.Action("Index", "PublicarProyecto")" class="add-btn">+ Nuevo Proyecto</a>
            </div>
        </form>

        <!-- Contador -->
        <div style="margin-bottom:16px; display:flex; align-items:center; gap:10px;">
            <span class="count-badge">
                @Model.Count proyecto@(Model.Count == 1 ? "" : "s") encontrado@(Model.Count == 1 ? "" : "s")
            </span>
            @if (!string.IsNullOrWhiteSpace(ViewBag.Buscar as string))
            {
                <a href="@Url.Action("Index", "GestionProyectos")"
                   style="font-size:13px; color:#118ab2; text-decoration:none;">
                    ✕ Limpiar búsqueda
                </a>
            }
        </div>

        <!-- Tabla -->
        <div class="table-card">
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <strong>No hay proyectos registrados</strong>
                    <p>Crea tu primer proyecto usando el botón "+ Nuevo Proyecto".</p>
                </div>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Imagen</th>
                            <th>Proyecto</th>
                            <th>Descripcion</th>
                            <th>Constructora</th>
                            <th>Estado</th>
                            <th>Fechas</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td>
                                        @{
                                            var imagen = p.ImagenesProyecto?.FirstOrDefault();
                                        }
                                        @if (imagen != null)
                                        {
                                            <img src="@imagen.URL" alt="@p.Nombre"/>    
                                        } else
                                        {
                                            <span class="sin-imagen">Sin imagen</span>
                                        }
                                    </td>
                                <td><strong>@p.Nombre</strong></td>
                                <td class="descripcion">
                                    @(string.IsNullOrWhiteSpace(p.Descripcion) ? "-" : p.Descripcion)
                                </td>
                                <td>@(p.Constructora?.Nombre ?? "—")</td>
                                <td>@(p.EstadoProyecto?.Descripcion  ?? "Pendiente")</td>
                                <td>
                                    Inicio: @(p.FechaInicio?.ToString("dd/MM/yyyy") ?? "—")<br />
                                    Fin: @(p.FechaFin?.ToString("dd/MM/yyyy") ?? "—")
                                </td>
                                <td>
                                    <div class="actions">
                                        <a href="@Url.Action("Editar", "EditarProyecto", new { id = p.ProyectoID })" class="btn edit">Editar</a>
                                        <button class="btn delete"
                                                onclick="abrirModal(@p.ProyectoID, '@Html.Raw(p.Nombre.Replace("'", "\\'"))')">
                                            Eliminar
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- Modal eliminar -->
    <div id="modalEliminar" class="modal">
        <div class="modal-box">
            <h3>¿Eliminar proyecto?</h3>
            <p>Esta acción no se puede deshacer.</p>
            <div class="actions">
                <button type="button" onclick="cerrarModal()">Cancelar</button>
                <button type="button" id="btnConfirmarEliminar">Sí, eliminar</button>
            </div>
        </div>
    </div>

    <!-- Formulario oculto -->
    <form id="formEliminar" method="post" action="@Url.Action("Eliminar", "GestionProyectos")" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" />
    </form>

    <script>
        let proyectoIdAEliminar = null;

        function abrirModal(id, nombre) {
            proyectoIdAEliminar = id;
            document.querySelector('#modalEliminar .modal-box h3').textContent =
                `¿Eliminar "${nombre}"?`;
            document.getElementById('modalEliminar').classList.add('open');
        }

        document.getElementById('btnConfirmarEliminar').addEventListener('click', function () {
            if (!proyectoIdAEliminar) return;
            const form = document.getElementById('formEliminar');
            form.querySelector('input[name="id"]').value = proyectoIdAEliminar;
            form.submit();
        });

        function cerrarModal() {
            document.getElementById('modalEliminar').classList.remove('open');
            proyectoIdAEliminar = null;
        }

        document.getElementById('modalEliminar').addEventListener('click', function(e) {
            if (e.target.id === 'modalEliminar') {
                cerrarModal();
            }
        });
    </script>
</body>
</html>
