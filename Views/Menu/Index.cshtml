@model List<Proyecto_SkyInit.Models.Propiedad>

@{
    Layout = "_LayoutMenu";
    ViewData["Title"] = "Menu";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SkyInit Inmobiliaria</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <header id="header">
        <div class="topbar">
            <div class="logo">SkyInit</div>
            <div class="menu-toggle" onclick="toggleMenu()">&#9776;</div>
            <nav id="menu">
                <a asp-controller="Menu" asp-action="Index">Inicio</a>
                <a asp-controller="Menu" asp-action="Buscar">Buscar</a>
                <a asp-controller="Menu" asp-action="Proyectos">Proyectos</a>
                <a asp-controller="Menu" asp-action="Constructoras">Constructoras</a>
                <a asp-controller="Menu" asp-action="Servicios">Servicios</a>
                <a asp-controller="Menu" asp-action="Registrar" class="btn-registrar">Iniciar Sesión</a>
            </nav>
        </div>
        <div class="hero">
            <h1>Encuentra tu hogar ideal</h1>
            <p>Compra, vende o arrienda con SkyInit</p>
        </div>
    </header>
    <section class="contenedor">
        <h2 class="titulo">Propiedades Destacadas</h2>
        <div class="grid">
            @foreach (var propiedad in Model)
            {
                <div class="card">
                    <!-- Mostrar la primera imagen si existe -->
                    @{
                        var imgUrl = propiedad.Imagenes.FirstOrDefault()?.URL
                        ?? "https://via.placeholder.com/400x250?text=Sin+imagen";
                    }
                    <img src="@imgUrl" alt="@propiedad.Titulo" />

                    <div class="card-body">
                        <h3>@propiedad.Titulo</h3>
                        <div class="precio">@propiedad.Precio.ToString("C0")</div>
                        <div class="tipo-operacion">@propiedad.TipoOperacion?.Descripcion</div>
                        <div class="ubicacion">
                            @(string.IsNullOrEmpty(propiedad.Ciudad) ? propiedad.Direccion : propiedad.Ciudad)
                        </div>
                        <p>@propiedad.Descripcion</p>
                        <a asp-controller="Propiedades" asp-action="Detalle" asp-route-id="@propiedad.PropiedadID" class="boton">Ver más</a>
                    </div>
                </div>
            }

        </div>
    </section>
    <script>
        function toggleMenu() {
            document.getElementById("menu").classList.toggle("active");
        }
        const images = [
            "https://images.unsplash.com/photo-1600585154340-be6161a56a0c",
            "https://images.unsplash.com/photo-1568605114967-8130f3a36994",
            "https://images.unsplash.com/photo-1570129477492-45c003edd2be"
        ];
        let index = 0;
        const header = document.getElementById("header");
        function changeBackground() {
            header.style.backgroundImage = `url(${images[index]})`;
            index = (index + 1) % images.length;
        }
        changeBackground();
        setInterval(changeBackground, 5000);
    </script>
</body>
</html>
