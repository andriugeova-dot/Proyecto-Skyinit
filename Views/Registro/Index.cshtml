@{
    Layout = "~/Views/Shared/_LayoutRegistro.cshtml";
}

<div class="left">
    <div class="bg">
        <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c" class="active" />
        <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c" />
        <img src="https://images.unsplash.com/photo-1600585152220-90363fe7e115" />
    </div>

    <div class="overlay"></div>

    <div class="left-content">
        <h1>SkyInit</h1>
        <p>Encuentra tu hogar ideal</p>
    </div>
</div>

<div class="right">
    <div class="form-box">
        <h2>Crear cuenta</h2>

        @using (Html.BeginForm("Registrar", "Registro", FormMethod.Post))
        {
            <div class="input-group">
                @Html.TextBox("Nombre", null, new { placeholder = "Nombre", @class = "form-control", required = "required" })
            </div>

            <div class="input-group">
                @Html.TextBox("Correo", null, new { type = "email", placeholder = "Correo electrónico", @class = "form-control", required = "required" })
            </div>

            <div class="input-group">
                @Html.Password("contraseña", null, new { placeholder = "Contraseña", @class = "form-control", required = "required" })
            </div>

            <div class="input-group">
                @Html.Password("confirmarcontraseña", null, new { placeholder = "Confirmar contraseña", @class = "form-control", required = "required" })
            </div>

            <div class="input-group">
                @Html.TextBox("Telefono", null, new { placeholder = "Telefono", @class = "form-control", required = "required" })

                @if (ViewBag.Error != null)
                {
                    <div class="invalid-feedback" style="display:block">
                        @ViewBag.Error
                    </div>
                }
            </div>

            <button type="submit" class="btn">Registrarse</button>
        }
    </div>
</div>

@section Scripts {
    <script>
        const imgs = document.querySelectorAll(".bg img");
        let i = 0;

        setInterval(() => {
            imgs[i].classList.remove("active");
            i = (i + 1) % imgs.length;
            imgs[i].classList.add("active");
        }, 4000);

        const input = document.getElementById("Contraseña");
        const barra = document.getElementById("NivelSeguridad");

        input.addEventListener("input", () => {
            let valor = input.value;
            let fuerza = 0;

            if(valor.length >= 8) fuerza += 25;
            if(/[A-Z]/.test(valor)) fuerza += 25;
            if(/[0-9]/.test(valor)) fuerza += 25;
            if(/[^A-Za-z0-9]/.test(valor)) fuerza += 25;

            barra.style.width = fuerza + "%";

            if(fuerza < 50){
                barra.className = "progress-bar bg-danger";
            } else if (fuerza < 75)
            {
                barra.className = "progress-bar bg-warning";
            } else
            {
                barra.className = "progress-bar bg-success";
            }
        });
    </script>
}
