<!-- ▌MODAL SOLICITAR SERVICIO ▐ -->
<div class="modal-overlay" id="modalSolicitud">
    <div class="modal-content">
        <button type="button" class="modal-close" onclick="cerrarModal('modalSolicitud')">&times;</button>
        <div class="modal-header">
            <div class="modal-title-wrap">
                <h2>Solicitar servicio</h2>
                <p id="modalServicioNombre"></p>
            </div>
        </div>
        <div class="modal-body">
            <form asp-action="SolicitarServicio" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="servicioId" id="modalServicioId" />

                <div class="form-row">
                    <label for="modalNotas">Detalles adicionales (opcional)</label>
                    <textarea name="notas" id="modalNotas" rows="4"
                              placeholder="Ej: dirección del inmueble, disponibilidad de horario, descripción del problema..."></textarea>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-secondary" onclick="cerrarModal('modalSolicitud')">Cancelar</button>
                    <button type="submit" class="btn-confirm">✅ Enviar solicitud</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleUserMenu() {
            document.getElementById("user-menu").classList.toggle("active");
        }

        function toggleMenu() {
            document.getElementById("menu").classList.toggle("active");
        }

        // ── Imagen de fondo rotativa del header (igual que Menu) ──
        const images = [
            "https://images.unsplash.com/photo-1581092918056-0c4c3acd3789",
            "https://images.unsplash.com/photo-1581141849291-1125c7b692b5",
            "https://images.unsplash.com/photo-1599423300746-b62533397364"
        ];
        let index = 0;
        const header = document.getElementById("header");
        function changeBackground() {
            header.style.backgroundImage = `url(${images[index]})`;
            index = (index + 1) % images.length;
        }
        changeBackground();
        setInterval(changeBackground, 5000);

        // ── Modal de solicitud ──────────────────────────────
        function abrirModalSolicitud(servicioId, nombre) {
            document.getElementById('modalServicioId').value = servicioId;
            document.getElementById('modalServicioNombre').textContent = nombre;
            document.getElementById('modalSolicitud').classList.add('active');
        }

        function cerrarModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        document.querySelectorAll('.modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', function (e) {
                if (e.target === this) this.classList.remove('active');
            });
        });

        // ── Auto-dismiss toast ──────────────────────────────
        ['toast', 'toastErr'].forEach(tid => {
            const el = document.getElementById(tid);
            if (el) setTimeout(() => el.style.display = 'none', 4500);
        });
    </script>
}
