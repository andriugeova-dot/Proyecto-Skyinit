@model IEnumerable<Proyecto_SkyInit.Models.ServicioMantenimiento>
@{
    Layout = "_LayoutUsuariosMantenimientos";
    ViewData["Title"] = "Servicios de Mantenimiento";
}

@if (TempData["Mensaje"] != null)
{
    <div class="toast success" id="toast">@TempData["Mensaje"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="toast error" id="toastErr">@TempData["Error"]</div>
}

<header id="header">
    <div class="topbar">
        <div class="logo">SkyInit</div>
        <div class="menu-toggle" onclick="toggleMenu()">&#9776;</div>
        <nav id="menu">
            <a asp-controller="Menu" asp-action="Index">Inicio</a>
            <a asp-controller="Menu" asp-action="Propiedades">Propiedades</a>
            <a asp-controller="Menu" asp-action="Proyectos">Proyectos</a>
            <a asp-controller="Menu" asp-action="Servicios">Servicios</a>
            <a asp-controller="Menu" asp-action="Constructoras">Constructoras</a>
            @if (User.Identity!.IsAuthenticated)
            {
                <div class="user-profile">
                    <img src="@(ViewBag.FotoPerfil ?? "/img/default-avatar.svg")"
                         alt="Perfil"
                         class="profile-pic"
                         onclick="toggleUserMenu()" />
                    <div id="user-menu" class="user-menu">
                        <div class="user-menu-name">@User.Identity.Name</div>
                        <a asp-controller="Login" asp-action="Ajustes">⚙️ Ajustes</a>
                        <form asp-controller="Login" asp-action="LogoutPost" method="post">
                            <button type="submit">🚪 Cerrar sesión</button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <a asp-controller="Login" asp-action="Index" class="btn-registrar">Iniciar Sesión</a>
            }
        </nav>
    </div>
    <div class="hero-inner">
        <div class="hero-eyebrow">Cuidamos tu hogar</div>
        <h1>Mantenimiento <em>profesional</em> para tu vivienda</h1>
        <p class="hero-sub">Conecta con especialistas certificados para reparaciones, mantenimiento y mejoras en tu hogar, con la confianza que solo SkyInit te ofrece.</p>
    </div>
</header>

<section class="contenedor">
    <div class="section-header">
        <span class="section-eyebrow">Nuestra oferta</span>
        <h2 class="section-title">Servicios de Mantenimiento</h2>
        <p class="section-sub">Soluciones prácticas y confiables para el cuidado de tu hogar, con proveedores verificados por SkyInit</p>
    </div>
</section>

<section class="grid">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <span>🛠️</span>
            No hay servicios de mantenimiento disponibles por el momento.
        </div>
    }
    else
    {
        foreach (var servicio in Model)
        {
            <div class="card">
                <div class="card-img-container">
                    @if (!string.IsNullOrWhiteSpace(servicio.Imagen))
                    {
                        <img src="@servicio.Imagen" alt="@servicio.Nombre">
                    }
                    else
                    {
                        <div class="card-icon-placeholder">🛠️</div>
                    }
                    <span class="badge-tipo">Disponible</span>
                </div>
                <div class="card-content">
                    <h3>@servicio.Nombre</h3>
                    <p>@servicio.Descripcion</p>
                    <p class="price-tag">$@servicio.Precio.ToString("N0")</p>

                    @if (User.Identity!.IsAuthenticated)
                    {
                        <button type="button"
                                onclick="abrirModalSolicitud(@servicio.ServicioID, '@Html.Raw(servicio.Nombre.Replace("'", "\\'"))')">
                            Solicitar
                        </button>
                    }
                    else
                    {
                        <a asp-controller="Login" asp-action="Index" class="btn-login-required">
                            Inicia sesión para solicitar
                        </a>
                    }
                </div>
            </div>
        }
    }
</section>

