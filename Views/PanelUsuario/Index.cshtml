@{
    Layout = "_LayoutPanelUsuario";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Usuario - SkyInit</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

    <div class="user-container">

        <aside class="sidebar">

            <div class="logo">
                <h2>SkyInit</h2>
                <span>Panel Usuario</span>
            </div>

            <nav>
                <a asp-controller="PanelUsuario" asp-action="PanelPrincipal" class="active">Panel Principal</a>
                <a asp-controller="PanelUsuario" asp-action="Perfil">Perfil</a>
                <a href="#">Favoritos</a>
                <a href="#">Historial</a>
                <a href="#">Mantenimiento</a>
                <a href="#">Configuración</a>
                <a asp-controller="Login" asp-action="Logout">Cerrar sesión</a>
            </nav>

        </aside>

        <main class="content">

            <div class="topbar">

                <h1>Bienvenido, @Model.Nombre</h1>

                <p>
                    Gestiona tu cuenta y tus propiedades favoritas.
                </p>

            </div>

            <!-- ESTADÍSTICAS -->

            <section class="stats-grid">

                <div class="stat-card">

                    <h2>@Model.Favoritos.Count</h2>

                    <p>Propiedades Favoritas</p>

                </div>

                <div class="stat-card">

                    <h2>0</h2>

                    <p>Solicitudes Activas</p>

                </div>

            </section>

            <!-- PERFIL -->

            <section class="card">

                <h2>Mi Perfil</h2>

                <div class="profile">

                    <div class="profile-image">
                        <img src="@(string.IsNullOrEmpty(Model.FotoPerfil) ? "/img/default-avatar.svg" : Model.FotoPerfil)"
                             alt="Avatar de @Model.Nombre"
                             class="profile-pic" />
                    </div>

                    <div class="profile-info">

                        <p><strong>Nombre:</strong> @Model.Nombre</p>

                        <p><strong>Correo:</strong> @Model.Correo</p>

                        <p><strong>Teléfono:</strong> @Model.Telefono</p>

                        <button class="btn">
                            Editar Perfil
                        </button>

                    </div>
                </div>
            </section>
        </main>
    </div>
</body>
</html>