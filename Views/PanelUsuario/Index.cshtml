@{
    Layout = "_LayoutPanelUsuario";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Usuario - SkyInit</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

    <div class="user-container">

        <aside class="sidebar">

            <div class="logo">
                <h2>SkyInit</h2>
                <span>Panel Usuario</span>
            </div>

            <nav>
                <a href="#">Dashboard</a>
                <a href="#">Mi Perfil</a>
                <a href="#">Favoritos</a>
                <a href="#">Historial</a>
                <a href="#">Mantenimiento</a>
                <a href="#">Configuración</a>
                <a href="#">Cerrar Sesión</a>
            </nav>

        </aside>

        <main class="content">

            <div class="topbar">

                <h1>Bienvenido, Jhoan Cotamo</h1>

                <p>
                    Gestiona tu cuenta y tus propiedades favoritas.
                </p>

            </div>

            <!-- ESTADÍSTICAS -->

            <section class="stats-grid">

                <div class="stat-card">

                    <h2>8</h2>

                    <p>Propiedades Favoritas</p>

                </div>

                <div class="stat-card">

                    <h2>3</h2>

                    <p>Solicitudes Activas</p>

                </div>

            </section>

            <!-- PERFIL -->

            <section class="card">

                <h2>Mi Perfil</h2>

                <div class="profile">

                    <div class="profile-image">
                        👤
                    </div>

                    <div class="profile-info">

                        <p><strong>Nombre:</strong> Jhoan Cotamo</p>

                        <p><strong>Correo:</strong> jhoan@email.com</p>

                        <p><strong>Teléfono:</strong> +57 300 000 0000</p>

                        <button class="btn">
                            Editar Perfil
                        </button>

                    </div>

                </div>

            </section>

            <!-- FAVORITOS -->

            <section class="card">

                <h2>Propiedades Favoritas</h2>

                <div class="favorite-list">

                    <div class="favorite-item">
                        Casa Moderna - Bogotá
                    </div>

                    <div class="favorite-item">
                        Penthouse Medellín
                    </div>

                    <div class="favorite-item">
                        Apartamento Sky Living
                    </div>

                </div>

            </section>

            <!-- HISTORIAL -->

            <section class="card">

                <h2>Historial de Propiedades</h2>

                <div class="history-list">

                    <div class="history-item">
                        Casa Campestre - Hace 2 horas
                    </div>

                    <div class="history-item">
                        Apartamento Norte - Hace 1 día
                    </div>

                    <div class="history-item">
                        Proyecto Green House - Hace 3 días
                    </div>

                </div>

            </section>

            <!-- MANTENIMIENTO -->

            <section class="card">

                <h2>Solicitudes de Mantenimiento</h2>

                <table class="table">

                    <thead>

                        <tr>
                            <th>Solicitud</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                        </tr>

                    </thead>

                    <tbody>

                        <tr>
                            <td>Fuga de agua</td>
                            <td>05/06/2026</td>
                            <td>
                                <span class="status pending">
                                    Pendiente
                                </span>
                            </td>
                        </tr>

                        <tr>
                            <td>Problema eléctrico</td>
                            <td>01/06/2026</td>
                            <td>
                                <span class="status progress">
                                    En proceso
                                </span>
                            </td>
                        </tr>

                        <tr>
                            <td>Pintura exterior</td>
                            <td>25/05/2026</td>
                            <td>
                                <span class="status completed">
                                    Completado
                                </span>
                            </td>
                        </tr>

                    </tbody>

                </table>

                <br>

                <button class="btn">
                    Nueva Solicitud
                </button>

            </section>

        </main>

    </div>

</body>
</html>